    发币页核心逻辑
    // launch/page.tsx
const AVAILABLE_LTS = [
  { symbol: "BTC3L", name: "BTC 3x Long", address: "0x..." },
  { symbol: "ETH3L", name: "ETH 3x Long", address: "0x..." },
  { symbol: "SOL3S", name: "SOL 3x Short", address: "0x..." },
  // 从 indexing.bounce.tech/leveraged-tokens 动态拉取
];

function LaunchPage() {
  const [form, setForm] = useState({
    name: "", symbol: "", description: "",
    image: null, ltAddress: ""
  });

  async function handleLaunch() {
    // 1. 上传图片到 IPFS
    const imageUri = await uploadToIPFS(form.image);
    
    // 2. 调用工厂合约
    const factory = new ethers.Contract(
      FACTORY_ADDRESS, FACTORY_ABI, signer
    );
    const tx = await factory.launch(
      form.name, form.symbol,
      form.ltAddress, imageUri, form.description
    );
    const receipt = await tx.wait();
    
    // 3. 解析事件，获取新代币地址
    const event = receipt.logs.find(l => 
      l.topics[0] === LAUNCH_EVENT_TOPIC
    );
    router.push(`/token/${event.args.bondingCurve}`);
  }

  return (
    <div>
      <input placeholder="代币名称" onChange={...} />
      <input placeholder="代币符号" onChange={...} />
      
      {/* 核心：选择标的 */}
      <select onChange={e => setForm({...form, ltAddress: e.target.value})}>
        {AVAILABLE_LTS.map(lt => (
          <option key={lt.address} value={lt.address}>
            {lt.name}
          </option>
        ))}
      </select>
      
      <button onClick={handleLaunch}>发射 🚀</button>
    </div>
  );
}

实时价格Hook
// hooks/useTokenPrice.ts
export function useTokenPrice(curveAddress: string) {
  const [price, setPrice] = useState<bigint>(0n);
  const [ltPrice, setLtPrice] = useState<bigint>(0n);

  useEffect(() => {
    // WebSocket连接后端
    const ws = new WebSocket(WS_URL);
    
    ws.onopen = () => {
      ws.send(JSON.stringify({
        type: "subscribe",
        token: curveAddress
      }));
    };

    ws.onmessage = (e) => {
      const data = JSON.parse(e.data);
      if (data.type === "price" && data.token === curveAddress) {
        setPrice(BigInt(data.price));
        setLtPrice(BigInt(data.ltPrice));
      }
    };

    return () => ws.close();
  }, [curveAddress]);

  return { price, ltPrice };
}

毕业进度条
// components/GraduationBar.tsx
// 两个进度条：USD进度 + 供应进度，取最大值显示

function GraduationBar({ curveAddress }) {
  const { realReserveY, ltPrice, realReserveX } = useCurveState(curveAddress);

  // USD进度：当前LT价值 / 9000
  const usdValue = (realReserveY * ltPrice) / BigInt(1e18);
  const usdProgress = Number(usdValue) / 9000e6 * 100;

  // 供应进度：已卖出代币 / 7.5亿
  const MAX_CURVE_TOKENS = 750_000_000n * BigInt(1e18);
  const sold = MAX_CURVE_TOKENS - realReserveX;
  const supplyProgress = Number(sold * 100n / MAX_CURVE_TOKENS);

  const progress = Math.min(Math.max(usdProgress, supplyProgress), 100);

  return (
    <div>
      <div>毕业进度 {progress.toFixed(1)}%</div>
      <div style={{
        width: `${progress}%`,
        background: progress > 80 ? "#ff6b35" : "#00ff88",
        height: 8, borderRadius: 4,
        transition: "width 0.5s"
      }} />
      <div>USD: ${(Number(usdValue) / 1e6).toFixed(0)} / $9,000</div>
    </div>
  );
}


模块四：数据库（轻量
用 PostgreSQL 存储：
- tokens 表：地址、名称、创建者、LT地址、创建时间
- trades 表：交易哈希、买卖方向、金额、时间
- price_history 表：5分钟K线数据

不需要存链上已有的数据，只存需要前端展示的聚合数据