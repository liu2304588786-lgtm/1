bouncetech.js — 对接官方API
const BASE = "https://indexing.bounce.tech";

// 获取所有LT列表（可选哪些标的）
export async function getLeveragedTokens() {
  const res = await fetch(`${BASE}/leveraged-tokens`);
  const { data } = await res.json();
  return data; // 包含地址、杠杆倍数、标的资产、当前汇率
}

// 获取某个LT的当前价格（exchangeRate）
export async function getLTPrice(ltAddress) {
  const res = await fetch(`${BASE}/leveraged-tokens`);
  const { data } = await res.json();
  const lt = data.find(t => 
    t.address.toLowerCase() === ltAddress.toLowerCase()
  );
  // exchangeRate 是 1e18 为基准的定点数
  return BigInt(lt.exchangeRate);
}

// 获取协议总体数据
export async function getProtocolStats() {
  const res = await fetch(`${BASE}/protocol-metrics`);
  return (await res.json()).data;
}
onchain.js — 读链上合约
import { ethers } from "ethers";
import { BONDING_CURVE_ABI } from "./abis.js";

const provider = new ethers.JsonRpcProvider(
  "https://rpc.hyperliquid.xyz/evm"
);

// 读取某个代币的bonding curve状态
export async function getCurveState(curveAddress) {
  const curve = new ethers.Contract(
    curveAddress, BONDING_CURVE_ABI, provider
  );

  const [rx, ry, vx, vy, ltAddress] = await Promise.all([
    curve.realReserveX(),
    curve.realReserveY(),
    curve.virtualReserveX(),
    curve.virtualReserveY(),
    curve.ltToken(),
  ]);

  return { rx, ry, vx, vy, ltAddress };
}

// 计算当前代币价格（纯JS，不上链）
export function calcTokenPrice(vy, vx, ltPrice) {
  // p_token = (y * p_LT) / x
  // 注意单位换算：LT是1e18，USDC是1e6，代币是1e18
  return (vy * ltPrice) / vx;
}

// 预测买入价格（报价）
export function quoteBuy(usdcIn, vx, vy, ltPrice) {
  // 先算能买到多少LT
  const ltIn = (usdcIn * BigInt(1e18)) / ltPrice;
  // xy=k，新的x
  const k = vx * vy;
  const newVy = vy + ltIn;
  const newVx = k / newVy;
  const tokenOut = vx - newVx;
  return tokenOut;
}

graduation.js — 毕业监控（Keeper Bot）
import { ethers } from "ethers";

// 每30秒检查所有存活曲线是否达到毕业条件
export async function startGraduationKeeper(curveAddresses) {
  const wallet = new ethers.Wallet(process.env.KEEPER_PRIVATE_KEY, provider);
  
  setInterval(async () => {
    for (const addr of curveAddresses) {
      try {
        const curve = new ethers.Contract(addr, BONDING_CURVE_ABI, wallet);
        const shouldGraduate = await curve.checkGraduation();
        
        if (shouldGraduate) {
          console.log(`毕业触发: ${addr}`);
          const tx = await curve.graduate({ gasLimit: 500000 });
          await tx.wait();
          console.log(`毕业完成: ${tx.hash}`);
          // 从监控列表移除
          curveAddresses.delete(addr);
        }
      } catch (e) {
        console.error(`检查失败 ${addr}:`, e.message);
      }
    }
  }, 30_000);
}

price.js — 价格聚合与推送（WebSocket）
import { WebSocketServer } from "ws";

// 维护所有代币的实时价格
const priceCache = new Map();

// 每5秒刷新LT价格，推送给前端
export function startPriceFeed(wss, activeCurves) {
  setInterval(async () => {
    const ltPrices = await getLTPrice(); // 批量拉取
    
    for (const [curveAddr, curveData] of activeCurves) {
      const ltPrice = ltPrices.get(curveData.ltAddress);
      const tokenPrice = calcTokenPrice(
        curveData.vy, curveData.vx, ltPrice
      );
      
      priceCache.set(curveAddr, tokenPrice);
      
      // 广播给所有订阅该代币的前端客户端
      wss.clients.forEach(client => {
        if (client.subscriptions?.has(curveAddr)) {
          client.send(JSON.stringify({
            type: "price",
            token: curveAddr,
            price: tokenPrice.toString(),
            timestamp: Date.now()
          }));
        }
      });
    }
  }, 5000);
}

